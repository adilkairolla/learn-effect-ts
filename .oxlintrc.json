{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "plugins": ["typescript", "react"],
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "ignorePatterns": [
    "**/routeTree.gen.ts",
    "dist",
    ".wrangler",
    "node_modules"
  ]
}
